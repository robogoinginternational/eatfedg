import cv2

# GStreamer pipeline for libcamera
pipeline = "libcamerasrc ! videoconvert ! appsink"
cap = cv2.VideoCapture(pipeline, cv2.CAP_GSTREAMER)

if not cap.isOpened():
    print("Cannot open camera")
    exit()

ret, frame = cap.read()
if ret:
    cv2.imshow("Camera Test", frame)
    cv2.waitKey(0)
cap.release()
cv2.destroyAllWindows()
